{
  "name": "babyjubjub-starknet",
  "version": "0.1.0",
  "description": "Baby Jubjub El Gamal encryption for Starknet. The serialization primitive for Baby Jubjub ↔ Circom ↔ Cairo.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./browser": "./dist/browser.js",
    "./dist/babyJub.js": "./dist/babyJub.js",
    "./dist/keypair.js": "./dist/keypair.js",
    "./dist/elgamal.js": "./dist/elgamal.js",
    "./dist/deck.js": "./dist/deck.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": ["starknet", "babyjubjub", "elgamal", "zk", "cairo", "circom"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/test/**/*.test.ts"],
    "testTimeout": 60000
  }
}
